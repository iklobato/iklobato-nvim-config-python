# Database UI runtime data
db_ui/queries/
db_ui/connections.json

# Neovim runtime directories
**/.local/share/nvim/
**/.local/state/nvim/
**/.cache/nvim/

# Plugin directories (managed by lazy.nvim)
**/lazy/
**/packer/

# Lock files (keep lazy-lock.json for reproducibility)
# lazy-lock.json is tracked

# Temporary files
*.swp
*.swo
*~
.*.sw?
*.tmp
*.bak
*.orig

# OS files
.DS_Store
Thumbs.db

# Claude settings
**/.claude/settings.local.json

# Logs
*.log

# Homebrew Bundle
# Brewfile is tracked by default for environment reproducibility
# Uncomment the line below if you want to ignore it (user-specific packages)
# Brewfile
Brewfile.backup.*
**/connections.json
.cursor/
.specify/

db_ui/connections.json
.aider*

# Secrets - never commit. Only the *.example templates are tracked.
.secrets.env
secrets.env
*.secret
.env
.env.*
!*.example
.pypirc
.npmrc
**/gh/hosts.yml
.aws/credentials
# SSH private keys
id_rsa
id_ed25519
id_ecdsa
*.pem
*.key
