# Machine-local secrets - TEMPLATE.
#
# Copy to ~/.secrets.env and fill in real values. The real file is git-ignored
# and sourced by system/zshrc on every shell start.
#
#   cp system/secrets.env.example ~/.secrets.env && chmod 600 ~/.secrets.env
#
# Only put env-style secrets here (tokens/keys tools read from the environment).
# File-based credentials are NOT env vars and stay as their own files, kept out
# of git by .gitignore:
#   - SSH keys:            ~/.ssh/id_ed25519, ~/.ssh/id_rsa
#   - AWS credentials:     ~/.aws/credentials   (or use the AWS_* vars below)
#   - GitHub CLI:          ~/.config/gh/hosts.yml (or use GH_TOKEN below)

# npm - make ~/.npmrc reference this instead of an inline token:
#   //registry.npmjs.org/:_authToken=${NPM_TOKEN}
export NPM_TOKEN=""

# PyPI / twine - lets you delete ~/.pypirc and publish with env vars:
export TWINE_USERNAME="__token__"
export TWINE_PASSWORD=""

# GitHub CLI and git operations (overrides ~/.config/gh/hosts.yml token):
export GH_TOKEN=""

# AWS (alternative to ~/.aws/credentials):
export AWS_ACCESS_KEY_ID=""
export AWS_SECRET_ACCESS_KEY=""

# Add any other tokens your ~/.config/secrets.env currently holds here.
